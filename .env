# Copy this file to .env for local runs.
#
# IMPORTANT: This key is BACKEND-ONLY. It is never entered through any UI
# textbox in this project. Set it as:
#   - Local/CLI:      this .env file (loaded via python-dotenv)
#   - Streamlit Cloud: App -> Settings -> Secrets -> GROQ_API_KEY = "gsk_xxx"
#   - Vercel:          Project -> Settings -> Environment Variables -> GROQ_API_KEY

# Optional. Get a free key at https://console.groq.com
# Without this, the pipeline still runs fully — it just uses rule-based
# fallbacks instead of LLM-based deal extraction & summary writing.
GROQ_API_KEY=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

# Optional. Defaults to llama-3.3-70b-versatile if unset.
GROQ_MODEL=llama-3.3-70b-versatile
